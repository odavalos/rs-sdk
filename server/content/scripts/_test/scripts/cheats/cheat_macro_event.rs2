[debugproc,macro_event](int $event)
if_close;
if (p_finduid(uid) = false) {
    @please_finish;
    return;
}
if ($event < 1 | $event > add(~macro_event_general_count,1)) {
    mes("event_id must be between 1 and <tostring(add(~macro_event_general_count,1))>.");
    @debugusage("::macro_event (event_id)", "::macro_event 2", "");
    return;
}
~macro_event_general_spawn($event);

[debugproc,random_event]
if_close;
if (p_finduid(uid) = false) {
    @please_finish;
    return;
}
~macro_event_general_spawn(~macro_event_set_random);

[debugproc,random]
if (p_finduid(uid) = true) {
    %macro_event = ^no_macro_event;
}
